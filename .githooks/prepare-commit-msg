#!/bin/sh

MSG_FILE="$1"
SOURCE="$2"

case "$SOURCE" in
  merge|squash|commit)
    exit 0
    ;;
esac

# If a non-comment message already exists, keep it.
if grep -q '^[^#[:space:]].*' "$MSG_FILE"; then
  exit 0
fi

FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$FILES" ]; then
  exit 0
fi

COUNT=$(printf "%s\n" "$FILES" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')
FIRST=$(printf "%s\n" "$FILES" | head -n 1)

if [ "$COUNT" -eq 1 ]; then
  SUBJECT="Update $FIRST"
elif [ "$COUNT" -le 3 ]; then
  LIST=$(printf "%s\n" "$FILES" | paste -sd ', ' -)
  SUBJECT="Update $LIST"
else
  AREAS=$(printf "%s\n" "$FILES" | awk -F/ '{print $1}' | sort -u | head -n 3 | paste -sd ', ' -)
  SUBJECT="Update $COUNT files"
  if [ -n "$AREAS" ]; then
    SUBJECT="$SUBJECT across $AREAS"
  fi
fi

SHORTSTAT=$(git diff --cached --shortstat)

{
  printf "%s\n\n" "$SUBJECT"
  printf "# Auto-generated by .githooks/prepare-commit-msg\n"
  if [ -n "$SHORTSTAT" ]; then
    printf "# %s\n" "$SHORTSTAT"
  fi
  printf "# Changed files:\n"
  printf "%s\n" "$FILES" | sed 's/^/# - /'
} > "$MSG_FILE"